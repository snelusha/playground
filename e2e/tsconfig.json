{
	"compilerOptions": {
		"target": "ES2023",
		"lib": ["ES2023", "DOM"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["node", "@playwright/test"],
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force"
	},
	"include": ["playwright.config.ts", "tests/**/*.ts"]
}
