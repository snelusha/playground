{
	"extends": ["//"],
	"tasks": {
		"copy:wasm": {
			"dependsOn": ["@playground/wasm#build"],
			"inputs": [
				"../../packages/wasm/dist/ballerina.wasm",
				"../../packages/wasm/dist/ballerina-meta.json"
			],
			"outputs": ["public/ballerina.wasm", "public/ballerina-meta.json"]
		},
		"build": {
			"dependsOn": ["^build", "copy:wasm"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"dependsOn": ["copy:wasm"],
			"cache": false,
			"persistent": true
		},
		"preview": {
			"dependsOn": ["build"],
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build", "copy:wasm"],
			"cache": false
		}
	}
}
